# Copy this file to .env (which is gitignored) and fill in your own values.
# Example:
#   cp .env.example .env

# SSH target used by scripts/remote-test.sh
REMOTE_TEST_HOST=your-ssh-user@your-host

# Optional remote workspace path (defaults to ~/kelvinclaw)
REMOTE_TEST_REMOTE_DIR=~/kelvinclaw

# Optional Docker image used by scripts/remote-test.sh --docker
REMOTE_TEST_DOCKER_IMAGE=rust:latest

# Optional Kelvin installed plugin home (default: ~/.kelvinclaw/plugins)
KELVIN_PLUGIN_HOME=~/.kelvinclaw/plugins

# Optional Kelvin publisher trust policy path (default: ~/.kelvinclaw/trusted_publishers.json)
KELVIN_TRUST_POLICY_PATH=~/.kelvinclaw/trusted_publishers.json

# Optional Kelvin local profile path (default: ~/.kelvinclaw/local-profile)
KELVIN_LOCAL_PROFILE_DIR=~/.kelvinclaw/local-profile

# Optional Kelvin state path (default: ~/.kelvinclaw/state)
KELVIN_STATE_DIR=~/.kelvinclaw/state

# Docker Compose Configuration
# See docs/docker.md for usage.

# Logging level for Rust applications
RUST_LOG=info

# Kelvin Host Configuration
HOST_PORT=8080

# Memory API Configuration (if using RPC memory backend)
MEMORY_API_PORT=50051

# Gateway Configuration
GATEWAY_PORT=3000

# Registry Configuration
REGISTRY_PORT=8888

# Gateway auth token — REQUIRED for docker compose up (public bind is rejected without it)
# Generate with: openssl rand -hex 32
KELVIN_GATEWAY_TOKEN=change-me

# Host port mappings (optional overrides)
KELVIN_GATEWAY_INGRESS_PORT=34618
KELVIN_PLUGIN_REGISTRY_PORT=34718

# Test lane for docker compose build kelvin-test (quick|full)
# KELVIN_TEST_LANE=full

# Model provider (kelvin.echo works out of the box with no API keys)
KELVIN_MODEL_PROVIDER=kelvin.echo

# To use a real LLM, uncomment ONE of the following and supply your API key:
# KELVIN_MODEL_PROVIDER=kelvin.openai
# OPENAI_API_KEY=your-openai-api-key

# KELVIN_MODEL_PROVIDER=kelvin.anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Anthropic configuration for the kelvin-gateway model provider (kelvin.anthropic)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: override base URL for an Anthropic-compatible endpoint
# ANTHROPIC_BASE_URL=https://api.anthropic.com
