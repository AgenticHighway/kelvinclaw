# Plugin distribution for release bundles uses the public plugin index.
# Set KELVIN_PLUGIN_INDEX_URL and use ./start-gateway or ./setup-gateway to install plugins.
#
# Docker builds continue to use plugins baked into the image via
# docker/Dockerfile.runtime (plugin-builder stage → /opt/kelvin/plugins-builtin/).
#
# ---------------------------------------------------------------------------
# Legacy manifest variables for release launchers
#
# The release launchers (kelvin-release-launcher.sh / kelvin-release-launcher.ps1)
# historically parsed plugin metadata from this file using the variables below.
# They are retained here for backward compatibility with tooling and CodeQL rules.
# The recommended mechanism for installing plugins is still the plugin index
# (see KELVIN_PLUGIN_INDEX_URL above).
#
# If you need the launchers to bootstrap a specific CLI build from a static
# package URL, populate these values appropriately.
#
# Example (do NOT uncomment or change unless you have the correct values):
# KELVIN_CLI_VERSION="1.2.3"
# KELVIN_CLI_PACKAGE_URL="https://example.com/kelvin-cli-1.2.3.tar.gz"
# KELVIN_CLI_SHA256="<expected-sha256-checksum>"
#
# By default, we define these variables as empty placeholders so that they
# exist for the launchers and static analysis, without changing behavior for
# plugin-index–based installs.

KELVIN_CLI_VERSION=""
KELVIN_CLI_PACKAGE_URL=""
KELVIN_CLI_SHA256=""
