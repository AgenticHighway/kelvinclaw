# KelvinClaw Release Bundle — Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# Model Provider
# Choose a model provider. kelvin.echo requires no API key (responses are echoed back).
KELVIN_MODEL_PROVIDER=kelvin.echo

# Uncomment ONE provider block and supply its API key:

# KELVIN_MODEL_PROVIDER=kelvin.anthropic
# ANTHROPIC_API_KEY=

# KELVIN_MODEL_PROVIDER=kelvin.openai
# OPENAI_API_KEY=

# KELVIN_MODEL_PROVIDER=kelvin.openrouter
# OPENROUTER_API_KEY=

# KELVIN_MODEL_PROVIDER=kelvin.ollama
# OLLAMA_BASE_URL=http://localhost:11434    # set to your Ollama server (no API key required)

# Plugin Index
# Required for: ./kpm install, ./kpm search, ./kpm update, ./kelvin-gateway auto-install.
KELVIN_PLUGIN_INDEX_URL=https://raw.githubusercontent.com/AgenticHighway/kelvinclaw-plugins/main/index.json

# Gateway
# Auth token for kelvin-gateway and kelvin-tui.
# Generate with: openssl rand -hex 32
KELVIN_GATEWAY_TOKEN=change-me

# Optional Tool Plugins
# BRAVE_API_KEY=          # required by the kelvin.websearch plugin

# Run Timeout
# Default is 300000ms (5 min). Increase for slow local models like Ollama.
# KELVIN_RUN_TIMEOUT_MS=300000

# Advanced Overrides (defaults are fine for most users)
# KELVIN_HOME=~/.kelvinclaw
# KELVIN_PLUGIN_HOME=~/.kelvinclaw/plugins
# KELVIN_TRUST_POLICY_PATH=~/.kelvinclaw/trusted_publishers.json
# KELVIN_STATE_DIR=~/.kelvinclaw/state
# KELVIN_DEFAULT_PROMPT=What is KelvinClaw?

# Launcher preferences (for example CLI vs TUI) are stored separately in:
#   ~/.kelvinclaw/preferences.env

# Gateway TLS (optional)
# KELVIN_GATEWAY_TLS_CERT_PATH=
# KELVIN_GATEWAY_TLS_KEY_PATH=
