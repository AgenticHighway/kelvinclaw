{
  "id": "kelvin.openai",
  "name": "Kelvin OpenAI Model Plugin",
  "version": "0.2.1",
  "api_version": "1.0.0",
  "description": "First-party OpenAI model plugin using Kelvin's provider_profile host routing.",
  "homepage": "https://github.com/agentichighway/kelvinclaw/tree/main/plugins/kelvin-openai-plugin",
  "capabilities": [
    "model_provider",
    "network_egress"
  ],
  "experimental": false,
  "min_core_version": "0.1.0",
  "max_core_version": null,
  "runtime": "wasm_model_v1",
  "provider_name": "openai",
  "provider_profile": {
    "id": "openai.responses",
    "provider_name": "openai",
    "protocol_family": "openai_responses",
    "api_key_env": "OPENAI_API_KEY",
    "base_url_env": "OPENAI_BASE_URL",
    "default_base_url": "https://api.openai.com",
    "endpoint_path": "v1/responses",
    "auth_header": "authorization",
    "auth_scheme": "bearer",
    "static_headers": [],
    "default_allow_hosts": [
      "api.openai.com"
    ]
  },
  "model_name": "gpt-4.1-mini",
  "entrypoint": "plugin.wasm",
  "entrypoint_sha256": "95e56a767278f83fa5372b4afa55475318e5e85071fbdc88f296fbeb09235050",
  "publisher": null,
  "quality_tier": "unsigned_local",
  "capability_scopes": {
    "fs_read_paths": [],
    "network_allow_hosts": [
      "api.openai.com"
    ]
  },
  "operational_controls": {
    "timeout_ms": 120000,
    "max_retries": 0,
    "max_calls_per_minute": 120,
    "circuit_breaker_failures": 3,
    "circuit_breaker_cooldown_ms": 30000
  }
}
