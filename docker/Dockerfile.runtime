# syntax=docker/dockerfile:1.7
ARG RUST_VERSION=1.93.1
ARG DEBIAN_FLAVOR=bookworm

FROM rust:${RUST_VERSION}-${DEBIAN_FLAVOR} AS builder
WORKDIR /work

COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
COPY apps ./apps
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/work/target \
    cargo build --release -p kelvin-host -p kelvin-cli && \
    cp /work/target/release/kelvin-host /usr/local/bin/kelvin-host && \
    cp /work/target/release/kelvin /usr/local/bin/kelvin

FROM rust:${RUST_VERSION}-${DEBIAN_FLAVOR} AS plugin-builder
RUN apt-get update && apt-get install -y --no-install-recommends jq && rm -rf /var/lib/apt/lists/*
RUN rustup target add wasm32-unknown-unknown
WORKDIR /build
COPY plugins/ ./plugins/
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    for plugin_dir in plugins/*/; do \
      if [ -f "${plugin_dir}build.sh" ]; then \
        echo "==> building plugin: ${plugin_dir}" && \
        cd "/build/${plugin_dir}" && bash build.sh && cd /build; \
      fi; \
    done

FROM debian:${DEBIAN_FLAVOR}-slim AS runtime
WORKDIR /opt/kelvin

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/bin/kelvin-host /usr/local/bin/kelvin-host
COPY --from=builder /usr/local/bin/kelvin /usr/local/bin/kelvin
COPY --from=plugin-builder /build/plugins/ /opt/kelvin/plugins-builtin/
COPY release/vendor/ /opt/kelvin/plugins-vendor/

ENV KELVIN_HOME=/kelvin
ENV KELVIN_PLUGIN_HOME=/kelvin/plugins
ENV KELVIN_TRUST_POLICY_PATH=/kelvin/trusted_publishers.json

ENTRYPOINT ["/usr/local/bin/kelvin-host"]
