# syntax=docker/dockerfile:1.7
ARG RUST_VERSION=1.93.1
ARG DEBIAN_FLAVOR=bookworm

FROM rust:${RUST_VERSION}-${DEBIAN_FLAVOR} AS builder
WORKDIR /work

COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
COPY apps ./apps
RUN cargo build --release -p kelvin-host

FROM debian:${DEBIAN_FLAVOR}-slim AS runtime
WORKDIR /opt/kelvin

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    jq \
    tar \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /work/target/release/kelvin-host /usr/local/bin/kelvin-host
COPY scripts/plugin-install.sh /opt/kelvin/scripts/plugin-install.sh
COPY scripts/plugin-index-install.sh /opt/kelvin/scripts/plugin-index-install.sh
COPY scripts/kelvin-setup.sh /opt/kelvin/scripts/kelvin-setup.sh
COPY scripts/runtime-entrypoint.sh /opt/kelvin/scripts/runtime-entrypoint.sh

RUN chmod +x /usr/local/bin/kelvin-host /opt/kelvin/scripts/*.sh

ENV KELVIN_HOME=/kelvin
ENV KELVIN_PLUGIN_HOME=/kelvin/plugins
ENV KELVIN_TRUST_POLICY_PATH=/kelvin/trusted_publishers.json

ENTRYPOINT ["/opt/kelvin/scripts/runtime-entrypoint.sh"]
