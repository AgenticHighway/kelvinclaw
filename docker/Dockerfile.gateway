# syntax=docker/dockerfile:1.7
ARG RUST_VERSION=1.93.1
ARG DEBIAN_FLAVOR=bookworm

FROM rust:${RUST_VERSION}-${DEBIAN_FLAVOR} AS builder
WORKDIR /work

COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
COPY apps ./apps
RUN cargo build --release -p kelvin-gateway

FROM debian:${DEBIAN_FLAVOR}-slim AS runtime
WORKDIR /opt/kelvin

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /work/target/release/kelvin-gateway /usr/local/bin/kelvin-gateway

RUN chmod +x /usr/local/bin/kelvin-gateway

ENV KELVIN_HOME=/kelvin
ENV KELVIN_PLUGIN_HOME=/kelvin/plugins
ENV KELVIN_TRUST_POLICY_PATH=/kelvin/trusted_publishers.json

ENTRYPOINT ["kelvin-gateway"]
