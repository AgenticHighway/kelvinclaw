# syntax=docker/dockerfile:1.7
ARG RUST_VERSION=1.93.1
ARG DEBIAN_FLAVOR=bookworm

FROM rust:${RUST_VERSION}-${DEBIAN_FLAVOR} AS builder
WORKDIR /work

COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
COPY apps ./apps
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    --mount=type=cache,target=/work/target \
    cargo build --release -p kelvin-registry && \
    cp /work/target/release/kelvin-registry /usr/local/bin/kelvin-registry

FROM debian:${DEBIAN_FLAVOR}-slim AS runtime
WORKDIR /opt/kelvin

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/bin/kelvin-registry /usr/local/bin/kelvin-registry

RUN chmod +x /usr/local/bin/kelvin-registry

ENTRYPOINT ["kelvin-registry"]
